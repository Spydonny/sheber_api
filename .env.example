# ==== Шебер — API маркетплейса ====
# Копируй в api/.env и заполни. Опционально: без переменных используются дефолты
# (локальный Mongo, порт 8000).

# ---- Mongo (общая БД с bot/; тут же в GridFS хранятся фото товаров) ----
MONGODB_URI=mongodb://localhost:27017
DB_NAME=sheber

# Домены фронта для CORS (через запятую); "*" — по умолчанию, для хакатона ок
CORS_ORIGINS=*

API_PORT=8000
